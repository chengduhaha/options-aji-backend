# ============================================================
# 阿吉美股期权平台 — 后端环境变量
# 复制为 .env 并填写真实值
#
# 也可改用「单文件」配置：复制 settings.example.toml 为 settings.toml（与 app/ 同级）。
# 优先级：环境变量 > settings.toml > .env > config.py 默认值；三者不必同时维护密钥。
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# PostgreSQL (推荐)
DATABASE_URL=postgresql+psycopg2://optionsaji:your_password@localhost:5432/optionsaji
# SQLite (仅本地测试)
# DATABASE_URL=sqlite:///./data/messages.db

# ── Redis 缓存 ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_HOT=900       # 热数据 TTL: 15 分钟 (期权快照/报价)
REDIS_CACHE_TTL_WARM=1800     # 温数据 TTL: 30 分钟 (新闻/评级)
REDIS_CACHE_TTL_COLD=21600    # 冷数据 TTL: 6 小时 (财务/ETF)
REDIS_CACHE_TTL_AI=3600       # AI摘要 TTL: 1 小时

# ── Massive API (期权数据) ───────────────────────────────────
MASSIVE_API_KEY=your_massive_api_key
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_WS_URL=wss://delayed.massive.com/options

# ── FMP API (股票/财务数据) ──────────────────────────────────
# 指数行情、宏观日历、国债收益率、国会交易、财报日历等均依赖此 Key；留空则多数市场情报接口返回空数组。
FMP_API_KEY=your_fmp_api_key
FMP_BASE_URL=https://financialmodelingprep.com/stable

# ── OpenRouter (LLM) ─────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_PARSE=deepseek/deepseek-chat
MODEL_SYNTHESIS=deepseek/deepseek-chat

# ── Discord (可选) ───────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
ENABLE_DISCORD_LISTENER=false
DISCORD_GAP_SYNC_ENABLED=false
DISCORD_GAP_SYNC_SECONDS=300

# ── Stripe 计费 (可选) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_SUCCESS_URL=https://options-aji.vercel.app/settings?billing=success
STRIPE_CANCEL_URL=https://options-aji.vercel.app/settings?billing=cancel
STRIPE_PORTAL_RETURN_URL=https://options-aji.vercel.app/settings?billing=portal
FREE_TIER_DAILY_AGENT_QUERIES=20

# ── 数据同步调度 ─────────────────────────────────────────────
# 核心期权链标的 (每15分钟同步)
SYNC_WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,PLTR,SOFI
# 是否启用数据同步
SYNC_ENABLED=true
# 同步时区
SYNC_TIMEZONE=America/New_York

# ── Feed 增强 ───────────────────────────────────────────────
FEED_ENRICHMENT_ENABLED=true
FEED_ENRICHMENT_INTERVAL_SECONDS=90
FEED_ENRICHMENT_BATCH_SIZE=8
FEED_ENRICHMENT_MAX_AGE_HOURS=72
FEED_ENRICHMENT_MODEL=

# ── 访问控制 ─────────────────────────────────────────────────
SUBSCRIPTION_TOKENS=
SUBSCRIPTION_REQUIRED=false
ADMIN_BACKFILL_TOKEN=

# ── JWT 用户登录（与前端 Auth）─────────────────────────────────
# 生产务必设置强随机串（不要用示例）。可用：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=24
# 逗号分隔：这些邮箱首次注册时自动 role=admin
AUTH_ADMIN_EMAILS=

# 注册限流（Redis）：同一 IP 在时间窗口内允许的注册请求次数（含失败次数）。
# 前端经 Vercel 代理时需转发客户端 IP 头，否则会多人共用出口 IP。
AUTH_REGISTER_RATE_LIMIT_ENABLED=true
AUTH_REGISTER_MAX_PER_HOUR=30
AUTH_REGISTER_WINDOW_SECONDS=3600

# ── CORS ─────────────────────────────────────────────────────
# 浏览器来源：必须包含你的 Vercel 前端域名（HTTPS）；本地开发可加 http://localhost:3000
CORS_ORIGINS=https://options-aji.vercel.app,http://localhost:3000

# ── 其他 ────────────────────────────────────────────────────
XPOZ_API_KEY=
XPOZ_BASE_URL=https://api.xpoz.ai/v1
XPOZ_RETRY_MAX=2
XPOZ_RETRY_BACKOFF_SECONDS=0.5
XPOZ_CIRCUIT_BREAKER_SECONDS=120

AGENT_DISCORD_CONTEXT_HOURS=72
AGENT_DISCORD_CONTEXT_LIMIT=18
RETENTION_DAYS=3
MACRO_FEED_CACHE_SECONDS=900
CBOE_EQUITY_PC_CACHE_SECONDS=3600
SUPPRESS_NOISY_PROVIDER_LOGS=true
INTEGRATION_STATUS_PUBLIC=true
LOG_LEVEL=INFO
