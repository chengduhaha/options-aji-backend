# 复制为 `.env` 并自行填写，勿将真实 Token 提交到 Git。

# Discord（需开启 Message Content Intent）
DISCORD_BOT_TOKEN=
# 逗号分隔多个频道；示例为「实时美股消息区」
DISCORD_CHANNEL_IDS=1475820725251215411
DISCORD_EVENT_CHANNEL_IDS=

ENABLE_DISCORD_LISTENER=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_PARSE=deepseek/deepseek-chat
MODEL_SYNTHESIS=deepseek/deepseek-chat

OPENBB_API_KEY=

DATABASE_URL=sqlite:///./data/messages.db

# 与现有 OptionsAji GEX HTTP 对齐（对应前端 RAILWAY_API_URL）
GEX_BACKEND_URL=
# JSON 字符串，例如 {"X-API-Key":"..."}
GEX_BACKEND_HEADERS=

# 逗号分隔多个合法订阅令牌；SUBSCRIPTION_REQUIRED=true 时强制校验 Authorization: Bearer
SUBSCRIPTION_TOKENS=
SUBSCRIPTION_REQUIRED=false

RETENTION_DAYS=3

CORS_ORIGINS=*
